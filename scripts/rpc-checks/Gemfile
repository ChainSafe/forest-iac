# frozen_string_literal: true

source 'https://rubygems.org'

# `it` block parameters make Ruby 3.4 the hard syntax floor; fail fast at
# bundler instead of with a confusing mid-run NameError on older rubies.
ruby '>= 3.4'

# The dataset's daily files are served brotli-compressed; open-uri does not
# decode brotli, so inflate explicitly.
gem 'brotli'
